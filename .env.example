APP_NAME=TimeTrackingApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8077

# Local timezone for scheduled automations and timestamp display (data is stored in UTC).
USER_TIMEZONE=Europe/Sofia

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=
