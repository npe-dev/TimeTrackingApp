APP_NAME=TimeTrackingApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8077

# Local timezone for scheduled automations and timestamp display (data is stored in UTC).
USER_TIMEZONE=Europe/Sofia

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=

# Mail — used by the scheduled email report. Defaults to "log" (writes emails to
# storage/logs/laravel.log) so nothing is sent in local dev. Production flips
# MAIL_MAILER to "mailersend" and injects MAILERSEND_API_KEY via the deploy job.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
# Must be a domain verified in your MailerSend account (todo.npetrov.eu is verified).
MAIL_FROM_ADDRESS="reports@todo.npetrov.eu"
MAIL_FROM_NAME="${APP_NAME}"

# MailerSend (https://app.mailersend.com) API token for sending real emails.
MAILERSEND_API_KEY=
